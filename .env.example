# =============================================================================
# domo-mcp configuration
# =============================================================================
# Required: at least one of (DOMO_DEVELOPER_TOKEN + DOMO_INSTANCE) or
# (DOMO_CLIENT_ID + DOMO_CLIENT_SECRET).

# -- Auth: Developer Token (preferred for instance APIs: page tree, beast modes,
#    Redshift connector queries). Generate at:
#    https://{instance}.domo.com/admin/security/accesstokens
DOMO_INSTANCE=yourcompany
DOMO_DEVELOPER_TOKEN=

# -- Auth: OAuth2 client credentials (Domo Developer Portal -> Custom Apps).
#    Required for most public Platform APIs (datasets/cards/pages/users).
DOMO_CLIENT_ID=
DOMO_CLIENT_SECRET=

# -- Auth: optional Playwright browser fallback (lazy-loaded; install
#    `playwright` and run `npx playwright install chromium` if you use it).
DOMO_USERNAME=
DOMO_PASSWORD=

# -- Optional governance meta-dataset IDs used by domo_search_datasets and
#    domo_get_dataset_for_card. Skip if you don't have governance datasets.
DOMO_DATASETS_META_DATASET_ID=
DOMO_CARDS_META_DATASET_ID=

# -- HTTP behavior
DOMO_API_HOST=api.domo.com
DOMO_TIMEOUT_MS=60000
DOMO_MAX_RETRIES=3

# =============================================================================
# AI Gateway (optional - only needed for domo_generate_semantic_layer and
# domo_explain_card_in_business_terms). Pick one provider.
# =============================================================================
# AI_PROVIDER: openai | anthropic | gemini | grok
AI_PROVIDER=

# OpenAI (or any OpenAI-compatible endpoint via OPENAI_BASE_URL)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Anthropic Claude
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# xAI Grok (uses OpenAI-compatible API)
GROK_API_KEY=

# Override default model per provider (optional)
AI_MODEL=

# Logging
LOG_LEVEL=info
